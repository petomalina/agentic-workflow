{
  "name": "braindump",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && npm run lint:server && vite build",
    "preview": "vite preview",
    "lint": "tsc --noEmit",
    "lint:server": "tsc --noEmit -p tsconfig.server.json",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:evals": "RUN_AGENT_EVALS=1 jest src/agent/conversations.test.ts --forceExit",
    "dev:api": "BRAINDUMP_DEV_ROUTES=1 tsx watch server/index.ts",
    "start:api": "tsx server/index.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@genkit-ai/express": "^1.36.0",
    "@genkit-ai/google-genai": "^1.36.0",
    "better-sqlite3": "^12.10.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "drizzle-orm": "^0.45.2",
    "express": "^5.2.1",
    "genkit": "^1.36.0",
    "lucide-react": "^1.17.0",
    "node-cron": "^4.2.1",
    "radix-ui": "^1.5.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/better-sqlite3": "^7.6.13",
    "@types/express": "^5.0.6",
    "@types/jest": "^30.0.0",
    "@types/node": "^24.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/react": "^19.2.0",
    "@types/react-dom": "^19.2.0",
    "@vitejs/plugin-react": "^6.0.2",
    "drizzle-kit": "^0.31.10",
    "identity-obj-proxy": "^3.0.0",
    "jest": "^30.4.2",
    "jest-environment-jsdom": "^30.4.1",
    "tailwindcss": "^4.3.0",
    "ts-jest": "^29.4.11",
    "tsx": "^4.22.4",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.0",
    "vite": "^8.0.16"
  }
}
